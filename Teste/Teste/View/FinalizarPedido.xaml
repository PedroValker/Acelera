<Window x:Class="Teste.View.FinalizarPedido"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Carrinho"
        WindowState="Maximized"
        Background="#F2F2F2">

    <!-- ESTILOS -->
    <Window.Resources>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER (MESMO PADRÃO) -->
        <Grid Background="White" Grid.Row="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LINHA SUPERIOR -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🛒" FontSize="22" Margin="0,0,5,0"/>
                    <TextBlock Text="Basic"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1E22D8"/>
                </StackPanel>

                <!-- USUÁRIO + ÍCONES -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">

                    <TextBlock Text="Olá, Luiz Adalberto" Margin="10,0"/>

                    <TextBlock Text="??" FontSize="16" Margin="10,0"/>
                    <TextBlock Text="??" FontSize="16" Margin="10,0"/>
                </StackPanel>
            </Grid>

            <!-- MENU -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Button Content="Faça seu Pedido" Style="{StaticResource PrimaryButton}" Margin="5"/>
                <Button Content="Assinatura" Style="{StaticResource MenuButton}" Margin="5"/>
                <Button Content="Pedidos" Style="{StaticResource MenuButton}" Margin="5"/>
                <Button Content="Sobre" Style="{StaticResource MenuButton}" Margin="5"/>
                <Button Content="Entre em Contato" Style="{StaticResource MenuButton}" Margin="5"/>
            </StackPanel>

        </Grid>

        <!-- CONTEÚDO -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CARRINHO -->
            <StackPanel Grid.Column="0" Margin="20">
                <TextBlock Text="Carrinho"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Border Background="White" CornerRadius="10" Padding="15" Height="350">
                    <StackPanel>

                        <!-- Cabeçalho -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Qtd"/>
                            <TextBlock Text="Produto" Grid.Column="1"/>
                            <TextBlock Text="Valor" Grid.Column="2"/>
                        </Grid>

                        <!-- Produto -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <!-- QTD -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="-" Width="20"/>
                                <TextBlock Text="1" Margin="5,0"/>
                                <Button Content="+" Width="20"/>
                            </StackPanel>

                            <TextBlock Text="Cesta Premium" Grid.Column="1"/>
                            <TextBlock Text="R$ 574,50" Grid.Column="2"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- FINALIZAR PEDIDO -->
            <StackPanel Grid.Column="1" Margin="20">

                <TextBlock Text="Finalizar Pedido"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- RECEBEDOR -->
                <Border Background="White" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Recebedor" FontWeight="Bold"/>
                        <TextBlock Text="Maria José"/>
                    </StackPanel>
                </Border>

                <!-- ENDEREÇO -->
                <Border Background="White" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Endereço de Entrega" FontWeight="Bold"/>
                        <TextBlock Text="R. Prefeita Adelle de Moraes - Cachoeira Paulista,SP"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PAGAMENTO -->
                    <Border Background="White" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Forma de Pagamento" FontWeight="Bold"/>
                            <TextBlock Text="Dinheiro"/>
                            <TextBlock Text="Pix"/>
                            <TextBlock Text="Cartão de Débito"/>
                            <TextBlock Text="Cartão de Crédito"/>
                            <TextBlock Text="Boleto"/>
                        </StackPanel>
                    </Border>

                    <!-- TOTAL -->
                    <Border Background="White" CornerRadius="10" Padding="10" Grid.ColumnSpan="2">
                        <StackPanel>
                            <TextBlock Text="Total: R$ 574,50" FontWeight="Bold"/>
                            <TextBlock Text="Forma de pagamento: Pix"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- BOTÃO -->
                <Button Content="Finalizar Pedido"
                        Style="{StaticResource PrimaryButton}"
                        Height="50"
                        Margin="0,20,0,0"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>