<Window x:Class="Teste.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        WindowState="Maximized"
        Background="#F2F2F2">

    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Width" Value="400"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- FORM -->
        <Grid Grid.Column="0"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Width="600">

            <StackPanel HorizontalAlignment="Center">

                <TextBlock Text="Login"
                           FontSize="42"
                           FontWeight="Bold"
                           Margin="0,0,0,40"
                           TextAlignment="Center"/>

                <!-- Email -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="E-mail" Foreground="Gray"/>
                        <TextBox x:Name="EmailBox"
                                 Height="35"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Senha -->
                <Border Style="{StaticResource InputStyle}">
                    <Grid>

                        <!-- Password -->
                        <PasswordBox x:Name="SenhaBox"
                                     Height="35"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="18"
                                     PasswordChanged="SenhaBox_PasswordChanged"/>

                        <!-- Texto visível -->
                        <TextBox x:Name="SenhaVisivelBox"
                                 Height="35"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"
                                 Visibility="Collapsed"
                                 TextChanged="SenhaVisivelBox_TextChanged"/>

                        <!-- Placeholder -->
                        <TextBlock x:Name="SenhaPlaceholder"
                                   Text="Senha"
                                   Foreground="Gray"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>

                        <!-- Botão -->
                        <Button x:Name="BotaoSenha"
                                Content="Ver senha"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Blue"
                                Cursor="Hand"
                                Click="ToggleSenha_Click"/>

                    </Grid>
                </Border>

                <!-- Botão Entrar -->
                <Button Content="Entrar"
                        Height="50"
                        Width="400"
                        Background="#F4D000"
                        FontSize="18"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BotaoEntrar_Click"
                        Margin="0,20,0,10"/>

                <!-- Link -->
                <TextBlock HorizontalAlignment="Center" FontSize="14">
                    Não tem uma conta?
                    <Run Text=" Cadastre-se"
                         Foreground="Blue"
                         Cursor="Hand"
                         MouseDown="AbrirCadastro_Click"/>
                </TextBlock>

            </StackPanel>
        </Grid>

        <!-- BANNER -->
        <Border Grid.Column="1"
                Background="#1E22D8"
                CornerRadius="80,0,0,80"
                Padding="40">

            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">

                    <TextBlock Text="🛒 Basic"
                               FontSize="36"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="Bem vindo de volta!"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="50"/>

                </StackPanel>
            </Grid>

        </Border>

    </Grid>
</Window>