 <UserControl x:Class="Teste.View.CadastroProduto" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="#F2F2F2"><UserControl.Resources>
    <Style x:Key="InputStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#EDEDED"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="5"/>
    </Style>
</UserControl.Resources>
<ScrollViewer>
    <StackPanel Margin="40">
        <TextBlock Text="Cadastro de Produtos" FontSize="30" FontWeight="Bold" Margin="0,0,0,20"/>
            <Grid Margin="0,0,0,30">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- NOVA LINHA -->
                </Grid.RowDefinitions>

                <!-- NOME -->
                <Border Style="{StaticResource InputStyle}" Grid.Row="0" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="Nome do Produto" Foreground="Gray"/>
                        <TextBox x:Name="NomeProdutoBox" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- MARCA -->
                <Border Style="{StaticResource InputStyle}" Grid.Row="0" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="Marca" Foreground="Gray"/>
                        <TextBox x:Name="MarcaBox" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- CATEGORIA -->
                <Border Style="{StaticResource InputStyle}" Grid.Row="1" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="Categoria" Foreground="Gray"/>
                        <ComboBox x:Name="CategoriaBox">
                            <ComboBoxItem Content="Alimentos"/>
                            <ComboBoxItem Content="Limpeza"/>
                            <ComboBoxItem Content="Bebidas"/>
                            <ComboBoxItem Content="Outros"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- PREÇO -->
                <Border Style="{StaticResource InputStyle}" Grid.Row="1" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="Preço" Foreground="Gray"/>
                        <TextBox x:Name="PrecoBox"/>
                    </StackPanel>
                </Border>

                <!-- 🔥 PESO (NOVO) -->
                <Border Style="{StaticResource InputStyle}" Grid.Row="2" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="Peso (Ex: 2L, 10Kg, 500G)" Foreground="Gray"/>
                        <TextBox x:Name="PesoBox" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- LISTA -->
                <Border Style="{StaticResource InputStyle}" Grid.Row="3" Grid.ColumnSpan="2">
                    <StackPanel>
                        <TextBlock Text="Produtos Cadastrados" Foreground="Gray"/>

                        <ListView x:Name="ListaProdutos" Height="200">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nome" DisplayMemberBinding="{Binding Nome}" Width="150"/>
                                    <GridViewColumn Header="Marca" DisplayMemberBinding="{Binding Marca}" Width="120"/>
                                    <GridViewColumn Header="Categoria" DisplayMemberBinding="{Binding Categoria}" Width="120"/>
                                    <GridViewColumn Header="Preço" DisplayMemberBinding="{Binding Preco}" Width="100"/>
                                    <GridViewColumn Header="Peso" DisplayMemberBinding="{Binding Peso}" Width="100"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                    </StackPanel>
                </Border>

            </Grid>
            <Button Content="➕ Salvar Produto" Width="220" Height="45" Background="#1E22D8" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="SalvarProduto_Click"/>
    </StackPanel>
</ScrollViewer>
</UserControl>