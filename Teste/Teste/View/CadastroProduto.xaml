<Window x:Class="Teste.CadastroProdutos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Produtos"
        WindowState="Maximized"
        Background="#F2F2F2">

    <!-- ESTILO -->
    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- COLUNAS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL -->
        <Border Background="#1E22D8">
            <StackPanel Margin="20">

                <TextBlock Text="🛒 Basic"
                           FontSize="24"
                           Foreground="White"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Pedidos" Foreground="White" Margin="0,10"/>
                <TextBlock Text="Cadastro de Produtos" Foreground="White" FontWeight="Bold" Margin="0,10"/>
                <TextBlock Text="Pendências" Foreground="White" Margin="0,10"/>
                <TextBlock Text="Estatísticas" Foreground="White" Margin="0,10"/>
                <TextBlock Text="Clientes" Foreground="White" Margin="0,10"/>

            </StackPanel>
        </Border>

        <!-- CONTEÚDO -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="40">

                <!-- TÍTULO -->
                <TextBlock Text="Cadastro de Produtos"
                           FontSize="30"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- FORMULÁRIO -->
                <Grid Margin="0,0,0,30">

                    <!-- COLUNAS -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- LINHAS (ESSENCIAL 🔥) -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nome -->
                    <Border Style="{StaticResource InputStyle}" Grid.Row="0" Grid.Column="0">
                        <StackPanel>
                            <TextBlock Text="Nome do Produto" Foreground="Gray"/>
                            <TextBox x:Name="NomeProdutoBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Marca -->
                    <Border Style="{StaticResource InputStyle}" Grid.Row="0" Grid.Column="1">
                        <StackPanel>
                            <TextBlock Text="Marca" Foreground="Gray"/>
                            <TextBox x:Name="MarcaBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Categoria -->
                    <Border Style="{StaticResource InputStyle}" Grid.Row="1" Grid.Column="0">
                        <StackPanel>
                            <TextBlock Text="Categoria" Foreground="Gray"/>
                            <ComboBox x:Name="CategoriaBox"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <ComboBoxItem Content="Alimentos"/>
                                <ComboBoxItem Content="Limpeza"/>
                                <ComboBoxItem Content="Bebidas"/>
                                <ComboBoxItem Content="Outros"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Preço -->
                    <Border Style="{StaticResource InputStyle}" Grid.Row="1" Grid.Column="1">
                        <StackPanel>
                            <TextBlock Text="Preço" Foreground="Gray"/>
                            <TextBox x:Name="PrecoBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Descrição -->
                    <Border Style="{StaticResource InputStyle}" Grid.Row="2" Grid.ColumnSpan="2">
                        <StackPanel>
                            <TextBlock Text="Descrição" Foreground="Gray"/>
                            <TextBox x:Name="DescricaoBox"
                                     Height="70"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- BOTÃO -->
                <Button Content="➕ Salvar Produto"
                        Width="220"
                        Height="45"
                        Background="#1E22D8"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SalvarProduto_Click"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>