<Window x:Class="Teste.View.TelaPrincipalCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Basic"
        WindowState="Maximized"
        Background="#F2F2F2">

    <!-- ESTILOS -->
    <Window.Resources>

        <!-- Botão principal -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Botões do menu -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="Black"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1A2BE2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Background="White" Grid.Row="0" Height="100" Margin="0,0,0,230" Grid.RowSpan="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LINHA DE CIMA -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="20,0">

                    <TextBlock Text="🛒"
                       FontSize="22"
                       Margin="0,0,5,0"
                       Foreground="#1E22D8"/>

                    <TextBlock Text="Basic"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1E22D8"/>
                </StackPanel>

                <!-- Olá usuário (centralizado) -->
                <TextBlock x:Name="NomeUsuarioText"
                   Text="Olá, Usuário"
                   FontSize="18"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" Margin="445,15,0,0"/>

                <!-- Ícones (direita) -->
                <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="0,0,20,0">

                    <!-- Ícone perfil -->
                    <Button Width="35" Height="35" Margin="5">
                        <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Ícone carrinho -->
                    <Button Width="35" Height="35" Margin="5">
                        <TextBlock Text="🛒" FontSize="16" HorizontalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- LINHA DE BAIXO (MENU) -->
            <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Button Content="Faça seu Pedido" Style="{StaticResource PrimaryButton}" Margin="5" Width="223"/>
                <Button Content="Assinatura" Style="{StaticResource MenuButton}" Margin="5" Width="158"/>
                <Button Content="Pedidos" Style="{StaticResource MenuButton}" Margin="5" Width="133"/>
                <Button Content="Sobre" Style="{StaticResource MenuButton}" Margin="5" Width="110"/>
                <Button Content="Contato" Style="{StaticResource MenuButton}" Margin="5" Width="134"/>
            </StackPanel>

            <!-- Usuário -->
        </Grid>

        <!-- BANNER -->
        <Border Grid.Row="1" Margin="20" CornerRadius="10" ClipToBounds="True">
            <Image Source="banner.jpg" Stretch="UniformToFill"/>
        </Border>

        <!-- PRODUTOS -->
        <StackPanel Grid.Row="2" Margin="30">

            <TextBlock Text="Verifique nossos produtos"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="10"/>

            <UniformGrid Columns="3" HorizontalAlignment="Center">

                <!-- CARD 1 -->
                <Border Background="White" CornerRadius="10" Margin="15" Padding="15" Width="280">
                    <StackPanel>
                        <Image Source="cesta1.png" Height="140" Stretch="Uniform"/>
                        <TextBlock Text="Cesta Básica" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Text="R$248,89"/>

                        <Button Content="Comprar"
                                Background="#FFD700"
                                Margin="0,10,0,0"
                                Height="35"/>
                    </StackPanel>
                </Border>

                <!-- CARD 2 -->
                <Border Background="White" CornerRadius="10" Margin="15" Padding="15" Width="280">
                    <StackPanel>
                        <Image Source="cesta2.png" Height="140" Stretch="Uniform"/>
                        <TextBlock Text="Cesta Limpeza" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Text="R$230,30"/>

                        <Button Content="Comprar"
                                Background="#FFD700"
                                Margin="0,10,0,0"
                                Height="35"/>
                    </StackPanel>
                </Border>

                <!-- CARD 3 -->
                <Border Background="White" CornerRadius="10" Margin="15" Padding="15" Width="280">
                    <StackPanel>
                        <Image Source="cesta3.png" Height="140" Stretch="Uniform"/>
                        <TextBlock Text="Cesta Premium" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Text="R$794,38"/>

                        <Button Content="Comprar"
                                Background="#FFD700"
                                Margin="0,10,0,0"
                                Height="35"/>
                    </StackPanel>
                </Border>

            </UniformGrid>
        </StackPanel>

        <!-- FOOTER -->
        <Grid Grid.Row="3" Background="#1A2BE2">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🛒 Basic"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Contato: +55 11 8302-0238"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>