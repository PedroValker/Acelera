<UserControl x:Class="Teste.View.AcompanharPedidoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F2F2">

    <Grid Margin="30">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- IMAGEM -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="10">

            <StackPanel>
                <Image Source="cesta3.png"
                       Height="180"
                       Stretch="Uniform"/>

                <TextBlock Text="Cesta Premium"
                           FontWeight="Bold"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- INFORMAÇÕES -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="10">

            <StackPanel>

                <TextBlock Text="Pedido"
                           FontWeight="Bold"/>
                <TextBlock Text="Cesta Premium"
                           FontSize="16"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Recebedor"
                           FontWeight="Bold"/>
                <TextBlock Text="Maria José"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Endereço de Entrega"
                           FontWeight="Bold"/>
                <TextBlock Text="R. Prefeita Adelle de Moraes - Cachoeira Paulista,SP"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Forma de Pagamento"
                           FontWeight="Bold"/>
                <TextBlock Text="Pix"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Status do Pedido"
                           FontWeight="Bold"/>

                <Border Background="#F59E0B"
                        CornerRadius="5"
                        Padding="5"
                        Width="120"
                        Margin="0,5,0,10">

                    <TextBlock Text="Pendente"
                               HorizontalAlignment="Center"
                               Foreground="White"/>
                </Border>

                <!-- BOTÕES -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,20,0,0">

                    <Button Content="Editar Pedido"
                            Background="#1E40AF"
                            Foreground="White"
                            Width="140"
                            Height="35"
                            Margin="0,0,10,0"/>

                    <Button Content="Cancelar Pedido"
                            Background="#DC2626"
                            Foreground="White"
                            Width="160"
                            Height="35"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- RESUMO -->
        <Border Grid.Column="2"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="10">

            <StackPanel>

                <TextBlock Text="Total: R$ 574,50"
                           FontWeight="Bold"
                           FontSize="16"/>

                <TextBlock Text="Resumo do pedido:"
                           Margin="0,10,0,5"/>

                <ScrollViewer Height="200">
                    <StackPanel>

                        <TextBlock Text="2 - Azeite de Oliva Extra"/>
                        <TextBlock Text="3 - Arroz Arbóreo"/>
                        <TextBlock Text="1 - Café em Grãos"/>
                        <TextBlock Text="1 - Vinho Tinto"/>
                        <TextBlock Text="2 - Mix de Castanhas"/>
                        <TextBlock Text="1 - Chocolate"/>
                        <TextBlock Text="2 - Queijo Maturado"/>
                        <TextBlock Text="1 - Batata Frita"/>
                        <TextBlock Text="4 - Bolacha Recheada"/>

                    </StackPanel>
                </ScrollViewer>

                <TextBlock Text="Observações:"
                           Margin="0,10,0,0"
                           FontWeight="Bold"/>

                <TextBlock Text="• Trocar farinha por melancia doce"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>