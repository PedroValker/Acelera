<Window x:Class="Teste.View.Contato"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contato"
        WindowState="Maximized"
        Background="#F2F2F2" Width="938">

    <!-- ESTILOS -->
    <Window.Resources>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER (MESMO PADRÃO) -->
        <Grid Background="White" Grid.Row="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LINHA SUPERIOR -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🛒" FontSize="22" Margin="0,0,5,0"/>
                    <TextBlock Text="Basic"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1E22D8"/>
                </StackPanel>


                <!-- USUÁRIO + ÍCONES -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">

                    <TextBlock Text="Olá, Luiz Adalberto" Margin="10,0"/>
                    <TextBlock Text="👤" FontSize="16" Margin="10,0"/>
                    <TextBlock Text="🛒" FontSize="16" Margin="10,0"/>
                </StackPanel>
            </Grid>

            <!-- MENU -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Button Content="Faça seu Pedido" Style="{StaticResource PrimaryButton}" Margin="5"/>
                <Button Content="Assinatura" Style="{StaticResource MenuButton}" Margin="5"/>
                <Button Content="Pedidos" Style="{StaticResource MenuButton}" Margin="5"/>
                <Button Content="Sobre" Style="{StaticResource MenuButton}" Margin="5"/>
                <Button Content="Entre em Contato" Style="{StaticResource MenuButton}" Margin="5"/>
            </StackPanel>

        </Grid>

        <!-- CONTEÚDO -->
        <StackPanel Grid.Row="1" Margin="30">

            <!-- TÍTULO -->
            <TextBlock Text="Entre em Contato"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- INFO CONTATO -->
                <StackPanel Grid.Column="0" Margin="20">

                    <TextBlock Text="Informações de Contato"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <!-- EMAIL -->
                    <TextBlock Text="E-mail"/>
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,5">
                        <TextBlock Text="emaildaloja@exemplo.com"/>
                    </Border>

                    <!-- TELEFONE -->
                    <TextBlock Text="Telefone" Margin="0,10,0,0"/>
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,5">
                        <TextBlock Text="(12) 4002-8922"/>
                    </Border>

                    <!-- LOCALIZAÇÃO -->
                    <TextBlock Text="Localização" Margin="0,10,0,0"/>
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,5">
                        <TextBlock Text="Lorena, São Paulo"/>
                    </Border>

                </StackPanel>

                <!-- FORMULÁRIO -->
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="20">
                    <StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <TextBox Margin="5" Height="35" Text="Nome"/>
                            <TextBox Margin="5" Height="35" Grid.Column="1" Text="E-mail"/>
                        </Grid>

                        <TextBox Height="35" Margin="5" Text="Assunto"/>

                        <TextBox Height="150"
                                 Margin="5"
                                 Text="Sua mensagem"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>

                        <Button Content="Enviar Mensagem"
                                Background="#1E22D8"
                                Foreground="White"
                                Height="40"
                                Margin="5,15,5,0"
                                Cursor="Hand"/>

                    </StackPanel>
                </Border>

            </Grid>

        </StackPanel>

    </Grid>
</Window>