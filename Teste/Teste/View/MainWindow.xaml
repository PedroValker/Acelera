<Window x:Class="Teste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="#F2F2F2">

    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Width" Value="400"/>
        </Style>
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- ================= FORMULÁRIO ================= -->

        <Grid Grid.Column="0"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Width="600">

            <StackPanel HorizontalAlignment="Center">

                <TextBlock Text="Cadastro"
                           FontSize="42"
                           FontWeight="Bold"
                           Margin="0,0,0,25"
                           TextAlignment="Center"/>

                <!-- Nome -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Nome Completo" Foreground="Gray"/>
                        <TextBox x:Name="NomeBox"
                                 Height="35"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Email -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="E-mail" Foreground="Gray"/>
                        <TextBox x:Name="EmailBox"
                                 Height="35"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Telefone -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Número de Telefone" Foreground="Gray"/>
                        <TextBox x:Name="TelefoneBox"
                                 PreviewTextInput="TelefoneBox_PreviewTextInput"
                                 Height="35"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Senha -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Senha" Foreground="Gray"/>
                        <PasswordBox x:Name="SenhaBox"
                                     Height="35"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Confirmar -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Confirmar senha" Foreground="Gray"/>
                        <PasswordBox x:Name="ConfirmarSenhaBox"
                                     Height="35"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Botão -->
                <Button Content="Criar Conta"
                        Height="50"
                        Width="400"
                        Background="#F4D000"
                        FontSize="18"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CriarConta_Click"
                        Margin="0,20,0,10">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="25">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

                <TextBlock HorizontalAlignment="Center" FontSize="14">
                    Já tem uma conta?
                    <Hyperlink Foreground="Blue" Cursor="Hand" Click="Entrar_Click">
                        Entrar
                    </Hyperlink>
                </TextBlock>

            </StackPanel>

        </Grid>

        <!-- ================= BANNER ================= -->

        <Border Grid.Column="1"
                Background="#1E22D8"
                CornerRadius="80,0,0,80"
                Padding="40">

            <Grid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">

                    <TextBlock Text="🛒 Basic"
                               FontSize="36"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="Seja bem vindo!"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="50"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>