<Window x:Class="Teste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================= FORMULÁRIO ================= -->

        <Grid Grid.Column="0"
              VerticalAlignment="Center"
              HorizontalAlignment="Left"
              Margin="80,0,40,0"
              MaxWidth="600">

            <StackPanel>

                <TextBlock Text="Cadastro"
                           FontSize="42"
                           FontWeight="Bold"
                           Margin="50,25,25,25"/>

                <!-- Nome -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Nome Completo" Foreground="Gray"/>
                        <TextBox x:Name="NomeBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"
                                 Height="30"/>
                    </StackPanel>
                </Border>

                <!-- Email -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="E-mail" Foreground="Gray"/>
                        <TextBox x:Name="EmailBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"
                                 Height="30"/>
                    </StackPanel>
                </Border>

                <!-- Telefone -->
                <Border Style="{StaticResource InputStyle}" Width="294">
                    <StackPanel>
                        <TextBlock Text="Número de Telefone" Foreground="Gray"/>
                        <TextBox  x:Name="TelefoneBox"
                         PreviewTextInput="TelefoneBox_PreviewTextInput"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="18"
                         Height="30"/>
                    </StackPanel>
                </Border>

                <!-- Senha -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Senha" Foreground="Gray"/>
                        <PasswordBox x:Name="SenhaBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="18"
                                     Height="30"/>
                    </StackPanel>
                </Border>

                <!-- Confirmar -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Confirmar senha" Foreground="Gray"/>
                        <PasswordBox x:Name="ConfirmarSenhaBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="18"
                                     Height="30"/>
                    </StackPanel>
                </Border>

                <!-- Botão -->
                <Button Content="Criar Conta"
                        Height="55"
                        HorizontalAlignment="Stretch"
                        Background="#F4D000"
                        FontSize="20"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CriarConta_Click"
                        Margin="0,25,0,10">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="28">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

                <TextBlock HorizontalAlignment="Center" FontSize="16">
                    Já tem uma conta?
                    <Hyperlink Foreground="Blue" Cursor="Hand" Click="Entrar_Click">
                        Entrar
                    </Hyperlink>    
                </TextBlock>

            </StackPanel>

        </Grid>

        <!-- ================= BANNER ================= -->

        <Border
                Background="#1E22D8"
                CornerRadius="80,0,0,80"
                Padding="40" Grid.ColumnSpan="2" Margin="413,0,1,0">

            <Grid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">

                    <TextBlock Text="🛒 Basic"
                               FontSize="36"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="Seja bem vindo!"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="50"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>