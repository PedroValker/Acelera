<Window x:Class="Teste.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <!-- ================= RECURSOS ================= -->
    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- ================= LADO ESQUERDO ================= -->
        <Grid Grid.Column="0"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Width="500"
              Margin="50">

            <StackPanel>

                <TextBlock Text="Login"
                           FontSize="42"
                           FontWeight="Bold"
                           Margin="0,0,0,40"/>

                <!-- Email -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="E-mail" Foreground="Gray"/>
                        <TextBox x:Name="EmailBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Senha -->
                <Border Style="{StaticResource InputStyle}">
                    <StackPanel>
                        <TextBlock Text="Senha" Foreground="Gray"/>
                        <PasswordBox x:Name="SenhaBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="18"/>
                    </StackPanel>
                </Border>

                <!-- Botão -->
                <Button Content="Entrar"
                        Height="55"
                        Background="#F4D000"
                        Foreground="Black"
                        FontSize="20"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BotaoEntrar_Click"
                        Margin="0,25,0,10">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="28">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

                <!-- Link Cadastro -->
                <TextBlock HorizontalAlignment="Center" FontSize="16">
                    Não tem uma conta?
                    <Run Text=" Cadastre-se"
                         Foreground="Blue"
                         Cursor="Hand"
                         MouseDown="AbrirCadastro_Click"/>
                </TextBlock>

            </StackPanel>
        </Grid>

        <!-- ================= LADO DIREITO ================= -->
        <Border Grid.Column="1"
                Background="#1E22D8"
                CornerRadius="80,0,0,80"
                Padding="40">

            <Grid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">

                    <TextBlock Text="🛒 Basic"
                               FontSize="36"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="Bem vindo de volta!"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="50"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>