<Window x:Class="CadastroTela.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <!-- Mova os recursos para cá, logo após abrir o Window -->
    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- ================= LADO ESQUERDO ================= -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">

            <Grid>
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="450"
                            Margin="40">

                    <TextBlock Text="Cadastro"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,30"/>

                    <!-- Nome -->
                    <Border Style="{StaticResource InputStyle}">
                        <StackPanel>
                            <TextBlock Text="Nome Completo" Foreground="Gray"/>
                            <TextBox x:Name="NomeBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Email -->
                    <Border Style="{StaticResource InputStyle}">
                        <StackPanel>
                            <TextBlock Text="E-mail" Foreground="Gray"/>
                            <TextBox x:Name="EmailBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Telefone -->
                    <Border Style="{StaticResource InputStyle}">
                        <StackPanel>
                            <TextBlock Text="Número de Telefone" Foreground="Gray"/>
                            <TextBox x:Name="TelefoneBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Senha -->
                    <Border Style="{StaticResource InputStyle}">
                        <StackPanel>
                            <TextBlock Text="Senha" Foreground="Gray"/>
                            <PasswordBox x:Name="SenhaBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Confirmar -->
                    <Border Style="{StaticResource InputStyle}">
                        <StackPanel>
                            <TextBlock Text="Confirmar senha" Foreground="Gray"/>
                            <PasswordBox x:Name="ConfirmarSenhaBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Botão -->
                    <Button Content="Criar Conta"
                            Height="50"
                            Background="#F4D000"
                            Foreground="Black"
                            FontSize="18"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CriarConta_Click"
                            Margin="0,20,0,10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="25">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock HorizontalAlignment="Center">
                        Já tem uma conta?
                        <Run Text=" Entrar"
                             Foreground="Blue"
                             Cursor="Hand"/>
                    </TextBlock>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ================= LADO DIREITO ================= -->
        <Border Grid.Column="1"
                Background="#1E22D8"
                CornerRadius="60,0,0,60">

            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500"
                            Margin="40">

                    <TextBlock Text="🛒 Basic"
                               FontSize="30"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <TextBlock Text="Seja bem vindo!"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>